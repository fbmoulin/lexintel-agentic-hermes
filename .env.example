APP_ENV=local
APP_NAME=lex-kratos-agentic-core
APP_VERSION=0.1.0

# Real retrieval is OFF by default. Turn on ONLY for an explicit Qdrant task.
LEX_KRATOS_ENABLE_QDRANT=false
# QDRANT_PORT (client connect) and QDRANT_HOST_PORT (compose host bind) MUST match.
# 6533 avoids a foreign Qdrant that may already hold :6333.
QDRANT_HOST=localhost
QDRANT_PORT=6533
QDRANT_HOST_PORT=6533
QDRANT_COLLECTION=lex_kratos_chunks
# Optional override; default = sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 (384-dim).
LEX_KRATOS_EMBEDDING_MODEL=

# Integrações reais ficam desligadas na v0.1. Preencher apenas quando houver tarefa explícita.
# NENHUMA das chaves abaixo é lida pelo código v0.1 — são placeholders para fases
# futuras (o código só lê as variáveis LEX_KRATOS_* e QDRANT_* acima).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
