# ============================================================
# Lex Intelligentia — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com suas chaves.
# Nunca commite o arquivo .env no repositório!
# ============================================================

# --- Modelos de Linguagem ---
# Chave principal para análise jurídica (Recomendado: Claude 3.5 Sonnet ou Gemini 1.5 Pro)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# --- Geração de Imagens ---
# Chave para o Gerador de Imagens (Midjourney via API não oficial ou OpenAI DALL-E)
OPENAI_API_KEY=your_openai_api_key_here

# --- Geração de Áudio (Apresentador Vídeo) ---
# Chave da ElevenLabs para geração de voz faceless
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# --- Automação e Publicação (n8n) ---
# Webhook URL do n8n para enviar o conteúdo finalizado para publicação
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/lex-publish
N8N_API_KEY=your_n8n_api_key_here

# --- Configurações do Projeto ---
# Caminho absoluto para o banco de dados local
DB_PATH=/home/ubuntu/lex-intelligentia/lex_intelligentia.db
# Nível de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
